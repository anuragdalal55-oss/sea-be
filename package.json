{
  "name": "ediss-sea-backend",
  "version": "1.0.0",
  "description": "EDISS - Electronic Data Interchange for Shipping System - Backend",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prebuild": "node -e \"try{require('fs').rmSync('dist',{ recursive: true, force: true, maxRetries: 5, retryDelay: 150 })}catch(e){}\"",
    "seed": "ts-node src/seeder.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "typescript": "^5.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  }
}
